{
  "ci": {
    "collect": { "startServerCommand": "cd frontend && npm start", "url": ["http://localhost:3000/", "http://localhost:3000/products"], "numberOfRuns": 1 },
    "assert": { "assertions": { "categories:accessibility": ["error", { "minScore": 0.9 }], "categories:performance": ["warn", { "minScore": 0.75 }] } }
  }
}
